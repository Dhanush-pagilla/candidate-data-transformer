{
  "fields": [
    { "path": "full_name",     "from": "full_name",     "type": "string",   "required": true },
    { "path": "primary_email", "from": "emails[0]",     "type": "string",   "required": true },
    { "path": "phone",         "from": "phones[0]",     "type": "string",   "normalize": "E164" },
    { "path": "skills",        "from": "skills[].name", "type": "string[]", "normalize": "canonical" },
    { "path": "headline",      "from": "headline",      "type": "string" },
    { "path": "location",      "from": "location",      "type": "dict" },
    { "path": "links",         "from": "links",         "type": "dict" },
    { "path": "confidence",    "from": "overall_confidence", "type": "float" }
  ],
  "include_confidence": true,
  "on_missing": "null"
}
